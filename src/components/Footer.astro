---
const year = new Date().getFullYear();

const columns = [
  {
    heading: 'Product',
    links: [
      { label: 'Docs', href: '/docs/' },
      { label: 'Blog', href: '/blog/' },
      { label: 'Recipes', href: '/recipes/' },
    ],
  },
  {
    heading: 'Community',
    links: [
      { label: 'YouTube', href: 'https://www.youtube.com/@Flixirio' },
      { label: 'GitHub', href: 'https://github.com/flixir-io' },
    ],
  },
];
---

<footer class="border-t border-slate-200 bg-slate-50 dark:border-slate-800 dark:bg-slate-900">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="grid gap-10 sm:grid-cols-[2fr_1fr_1fr]">
      <div>
        <p class="text-lg font-semibold text-slate-900 dark:text-white">Flixir</p>
        <p class="mt-2 max-w-sm text-sm text-slate-600 dark:text-slate-400">
          Visual workflow automation for Shopify. Automate your store
          without writing code.
        </p>
      </div>

      {columns.map((col) => (
        <div>
          <p class="text-sm font-semibold text-slate-900 dark:text-white">{col.heading}</p>
          <ul class="mt-3 space-y-2">
            {col.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  class="text-sm text-slate-600 transition hover:text-brand-600 dark:text-slate-400 dark:hover:text-brand-400"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <p class="mt-10 border-t border-slate-200 pt-6 text-xs text-slate-500 dark:border-slate-800 dark:text-slate-500">
      &copy; {year} Flixir. All rights reserved.
    </p>
  </div>
</footer>
