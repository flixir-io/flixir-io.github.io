---
// Small, dependency-free theme toggle. A React island isn't needed here —
// this is exactly the kind of interactivity Astro says to keep as plain JS
// (see the migration spec's note on why Astro was chosen for this site).
---

<button
  id="theme-toggle"
  type="button"
  aria-label="Toggle dark mode"
  class="inline-flex h-9 w-9 items-center justify-center rounded-full text-slate-600 transition hover:bg-slate-100 dark:text-slate-300 dark:hover:bg-slate-800"
>
  <svg
    id="theme-toggle-sun"
    class="hidden h-5 w-5 dark:block"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41" />
  </svg>
  <svg
    id="theme-toggle-moon"
    class="h-5 w-5 dark:hidden"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
  >
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79Z" />
  </svg>
</button>

<script>
  // Runs on every navigation (Astro view transitions or plain reload) — the
  // FOUC-avoiding version of this same logic lives inline in
  // MarketingLayout.astro / DocsLayout.astro <head>, this just wires the
  // button up after hydration.
  const STORAGE_KEY = 'flixir-theme';

  function applyTheme(theme: 'light' | 'dark') {
    document.documentElement.classList.toggle('dark', theme === 'dark');
    localStorage.setItem(STORAGE_KEY, theme);
  }

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.contains('dark');
    applyTheme(isDark ? 'light' : 'dark');
  });
</script>
